#SET 11
# Data
category <- c("Electronics","Clothing","Appliances")
sales <- c(50000,35000,40000)

data <- data.frame(category, sales)

# 1. Funnel Chart (using barplot)
barplot(rev(sales), horiz=TRUE,
        names.arg=rev(category),
        main="Sales Funnel",
        col="skyblue", xlab="Sales")

# 2. Table
data

# 3. Pie Chart
pie(sales,
    labels=category,
    main="Sales Distribution",
    col=c("red","blue","green"))
