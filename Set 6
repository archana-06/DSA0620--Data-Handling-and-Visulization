
#SET 6
# Data
p <- c("A","B","C")
jan <- c(2000,1500,1200)
feb <- c(2200,1800,1400)
mar <- c(2400,1600,1100)

# 1. Grouped Bar
barplot(rbind(jan,feb,mar), beside=TRUE, names.arg=p)

# 2. Stacked Area
x <- 1:3
plot(x, jan+feb+mar, type="n")
polygon(c(x,rev(x)), c(jan+feb+mar, rev(jan+feb)))
polygon(c(x,rev(x)), c(jan+feb, rev(jan)))
polygon(c(x,rev(x)), c(jan, rep(0,3)))

# 3. Table
data.frame(p, jan, feb, mar)
