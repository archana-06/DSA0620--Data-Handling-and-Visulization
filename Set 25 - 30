likes <- c(200,250,180,220,300)
shares <- c(100,120,90,110,150)
comments <- c(50,60,40,55,70)

x <- 1:5
plot(x, likes+shares+comments, type="n",
     main="User Interactions",
     xlab="Day", ylab="Count")

