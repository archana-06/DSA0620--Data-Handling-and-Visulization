#SET28
# Data
engine <- c(1.5,2.0,3.0,2.5,1.8)
hp <- c(110,150,250,200,130)
fuel <- c(18,15,12,14,17)
speed <- c(180,200,250,220,190)
safety <- c(4,5,5,4,3)

data <- data.frame(engine, hp, fuel, speed, safety)

# 1. Violin Plot (use boxplot as simple alternative)
boxplot(fuel ~ safety,
        main="Fuel Efficiency by Safety Rating",
        xlab="Safety Rating",
        ylab="Fuel Efficiency",
        col=c("gold","purple","orange"))

# 2. Scatter Plot (HP vs Speed)
plot(hp, speed,
     col=engine,
     pch=16,
     main="Horsepower vs Top Speed",
     xlab="Horsepower",
     ylab="Top Speed")
legend("topleft",
       legend=unique(engine),
       col=unique(engine), pch=16)

# 3. Correlation Heatmap
corr <- cor(data)
heatmap(corr,
        main="Correlation Heatmap",
        col=heat.colors(10))









