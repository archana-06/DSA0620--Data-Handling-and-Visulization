#SET30
# Data
id <- c("U01","U02","U03","U04","U05","U06")
gender <- c("Male","Female","Male","Female","Male","Female")
age <- c(20,22,19,21,23,20)
screen <- c(4.5,6.0,3.2,7.1,2.8,5.4)
usage <- c(18,25,12,30,10,22)
data_used <- c(2.4,3.8,1.6,4.5,1.2,3.1)
satisfaction <- c(3,5,3,5,2,4)

data <- data.frame(id, gender, age, screen, usage, data_used, satisfaction)

# 1. Histogram + Density
hist(screen,
     col="gold",
     main="Screen Time Distribution",
     xlab="Screen Time (hrs)",
     prob=TRUE)

lines(density(screen),
      col="purple", lwd=2)

# 2. Scatter Plot + Correlation
plot(data_used, screen,
     pch=16,
     col="orange",
     main="Data Used vs Screen Time",
     xlab="Data Used (GB)",
     ylab="Screen Time (hrs)")

abline(lm(screen ~ data_used),
       col="brown", lwd=2)

correlation <- cor(data_used, screen)
correlation

# 3. Average Satisfaction by Gender
avg_sat <- tapply(satisfaction, gender, mean)

barplot(avg_sat,
        col=c("purple","gold"),
        main="Average Satisfaction by Gender",
        ylab="Satisfaction Score")

# Add value labels
text(1:2, avg_sat, labels=round(avg_sat,2), pos=3)
