#SET26
# Data
id <- c("S01","S02","S03","S04","S05","S06")
gender <- c("Male","Female","Male","Female","Male","Female")
study <- c(2.0,3.5,1.5,4.0,2.8,3.0)
att <- c(78,90,70,95,85,92)
math <- c(62,80,55,90,72,82)
sci <- c(65,85,58,92,74,86)
date <- as.Date(c("2025-01-10","2025-01-10",
                  "2025-02-12","2025-02-12",
                  "2025-03-15","2025-03-15"))

data <- data.frame(id, gender, study, att, math, sci, date)

# 1. Histogram (Math Score)
hist(math,
     main="Math Score Distribution",
     xlab="Math Score",
     col="lightgray")

# Boxplot (Science Score by Gender)
boxplot(sci ~ gender,
        main="Science Score by Gender",
        xlab="Gender",
        ylab="Score",
        col=c("orange","purple"))

# 2. Scatter Plot with Regression
plot(study, math,
     col=ifelse(gender=="Male","brown","darkorange"),
     pch=16,
     main="Study Hours vs Math Score",
     xlab="Study Hours",
     ylab="Math Score")
abline(lm(math~study), col="black", lwd=2)

# 3. Monthly Avg + Line Chart
month <- format(date, "%Y-%m")
avg <- tapply(math, month, mean)

plot(as.numeric(avg), type="o",
     main="Monthly Avg Math Score",
     xlab="Month",
     ylab="Average Score",
     col="purple")

# Moving Average
lines(filter(avg, rep(1/2,2), sides=1),
      col="brown", lwd=2)

