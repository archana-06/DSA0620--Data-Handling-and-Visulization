#SET24
# Data
id <- c(1,2,3,4,5)
product <- c("A","B","C","D","E")
qty <- c(250,175,300,200,220)
price <- c(20,15,18,22,19)   # assumed prices

data <- data.frame(id, product, qty, price)

# 1. Bar Chart (Quantity)
barplot(qty,
        names.arg=product,
        main="Product Quantity",
        xlab="Product",
        ylab="Quantity",
        col="orange")

# 2. Stacked Bar Chart (Quantity + Price)
stack_data <- rbind(qty, price)
barplot(stack_data,
        names.arg=product,
        main="Inventory Comparison",
        xlab="Product",
        ylab="Values",
        col=c("gold","purple"))
legend("topright", legend=c("Quantity","Price"),
       fill=c("gold","purple"))

# 3. Scatter Plot (Price vs Quantity)
plot(price, qty,
     main="Price vs Quantity",
     xlab="Price",
     ylab="Quantity",
     col="brown", pch=16)

