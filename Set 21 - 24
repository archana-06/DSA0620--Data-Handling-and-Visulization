

#SET21
# Data
sector <- c("Residential","Commercial","Industrial",
            "Residential","Commercial","Industrial")
region <- c("North","South","West","East","North","South")
month <- c("Jan","Jan","Feb","Feb","Mar","Mar")
temp <- c(15,24,20,18,28,30)
units <- c(320,540,880,350,610,920)
cost <- c(2100,3600,5900,2300,4100,6200)
renew <- c(22,18,12,25,20,15)
peak <- c(4,6,8,5,7,9)

data <- data.frame(sector, region, month, temp, units, cost, renew, peak)

# 1. Histogram + Density
hist(units, prob=TRUE,
     main="Units Consumed Distribution",
     xlab="Units (kWh)",
     col="lightgray")
lines(density(units), col="orange", lwd=2)

# 2. Scatter Plot (Bubble)
symbols(temp, units,
        circles=peak,
        inches=0.2,
        bg="purple",
        main="Temp vs Units",
        xlab="Temperature",
        ylab="Units Consumed")

# 3. Avg Renewable Usage (Bar Chart)
avg <- tapply(renew, sector, mean)
barplot(avg,
        main="Avg Renewable Usage by Sector",
        xlab="Sector",
        ylab="Percentage",
        col="gold")

# Data Table
data







#SET22
# Data
month <- c("Jan","Feb","Mar","Apr","May")
sales <- c(15000,18000,22000,20000,23000)
ad <- c(2000,2500,3000,2700,3200)   # sample advertising budget

# 1. Time Series Line Chart
ts_data <- ts(sales)
plot(ts_data, type="o",
     main="Monthly Sales Trend",
     xlab="Month", ylab="Sales",
     col="darkorange", lwd=2)

# 2. Scatter Plot (Ad vs Sales)
plot(ad, sales,
     main="Ad Budget vs Sales",
     xlab="Advertising Budget",
     ylab="Sales",
     col="purple", pch=16)

# 3. Autocorrelation Plot
acf(ts_data,
    main="Autocorrelation of Sales",
    col="brown")






