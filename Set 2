import pandas as pd

data = {
    "Customer_ID": [1, 2, 3, 4, 5],
    "Age": [25, 30, 35, 28, 40],
    "Satisfaction_Score": [4, 5, 3, 4, 5]
}

df = pd.DataFrame(data)
#Histogram – Distribution of Customer Ages
import matplotlib.pyplot as plt

plt.figure()
plt.hist(df["Age"], bins=5)
plt.title("Distribution of Customer Ages")
plt.xlabel("Age")
plt.ylabel("Frequency")
plt.show()

#Pie Chart – Satisfaction Score Distribution
score_counts = df["Satisfaction_Score"].value_counts()

plt.figure()
plt.pie(score_counts, labels=score_counts.index, autopct='%1.1f%%')
plt.title("Customer Satisfaction Distribution")
plt.show()

#Stacked Bar Chart – Satisfaction by Age Group
#Step 1: Create Age Groups
df["Age_Group"] = pd.cut(df["Age"], bins=[20, 30, 40, 50],
                        labels=["20-30", "30-40", "40-50"])
#Step 2: Create Pivot Table
pivot = df.pivot_table(index="Age_Group",
                       columns="Satisfaction_Score",
                       aggfunc="size",
                       fill_value=0)
#Step 3: Plot
pivot.plot(kind="bar", stacked=True)
plt.title("Satisfaction Score Distribution by Age Group")
plt.xlabel("Age Group")
plt.ylabel("Number of Customers")
plt.show()

#Word Cloud – Customer Feedback
from wordcloud import WordCloud

feedback = """
good service excellent support happy experience
great quality satisfied happy quick delivery
good good excellent satisfied
"""

wordcloud = WordCloud(width=800, height=400).generate(feedback)

plt.figure()
plt.imshow(wordcloud, interpolation='bilinear')
plt.axis("off")
plt.title("Customer Feedback Word Cloud")
plt.show()
