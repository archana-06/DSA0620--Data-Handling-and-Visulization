#set 20
# Data
date <- as.Date(c("2023-01-01","2023-01-02","2023-01-03"))
A <- c(100,105,110)
B <- c(150,152,148)
C <- c(120,118,122)

data <- data.frame(date, A, B, C)

# 1. Line Chart (Stock Prices)
plot(date, A, type="o", col="orange",
     ylim=c(100,155),
     main="Stock Price Trend",
     xlab="Date", ylab="Price")
lines(date, B, type="o", col="purple")
lines(date, C, type="o", col="brown")
legend("topleft",
       legend=c("Stock A","Stock B","Stock C"),
       col=c("orange","purple","brown"), lty=1)

# 2. Bar Chart (Daily % Change for Stock A)
pct <- diff(A)/A[-length(A)]*100
barplot(pct,
        names.arg=date[-1],
        main="Daily % Change (Stock A)",
        xlab="Date", ylab="% Change",
        col="gold")

