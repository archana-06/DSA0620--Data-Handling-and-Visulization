# Data
product <- c("A","B","C")
jan <- c(2000,1500,1200)
feb <- c(2200,1800,1400)
mar <- c(2400,1600,1100)

data <- data.frame(product, jan, feb, mar)

# 1. Grouped Bar Chart
barplot(rbind(jan,feb,mar), beside=TRUE,
        names.arg=product,
        main="Quarterly Sales",
        xlab="Product", ylab="Sales",
        col=c("red","blue","green"))
legend("topleft", legend=c("Jan","Feb","Mar"),
       fill=c("red","blue","green"))

# 2. Stacked Area Chart
x <- 1:3
plot(x, jan+feb+mar, type="n",
     main="Sales Trend",
     xlab="Month", ylab="Sales")

polygon(c(x,rev(x)), c(jan+feb+mar, rev(jan+feb)), col="lightblue")
polygon(c(x,rev(x)), c(jan+feb, rev(jan)), col="lightgreen")
polygon(c(x,rev(x)), c(jan, rep(0,3)), col="pink")

# 3. Table
data




